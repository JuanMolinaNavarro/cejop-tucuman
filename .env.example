# ============================================================================
# CEJOP Tucumán — Variables de entorno
# Copiá este archivo a .env.local y completá los valores.
# .env.local está en .gitignore: NO lo subas al repo.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
# Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo servidor. Salta RLS: usar únicamente en código de servidor confiable.
# NO tiene prefijo NEXT_PUBLIC_ para que nunca llegue al navegador.
SUPABASE_SERVICE_ROLE_KEY=

# --- Resend (emails) --------------------------------------------------------
# https://resend.com/api-keys
RESEND_API_KEY=
# Remitente (debe usar un dominio verificado en Resend)
RESEND_FROM="CEJOP Tucumán <no-reply@cejoptucuman.com>"
# Casilla interna para notificaciones de nuevas inscripciones (opcional)
CEJOP_NOTIFY_EMAIL=cejoptucuman@gmail.com
